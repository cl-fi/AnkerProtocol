# Anker Protocol — environment template
# Copy to `.env.local` for local overrides. Values fall back to committed
# testnet defaults in `src/config/*` and `contracts/anker_protocol/deployments/testnet.json`.
#
# All NEXT_PUBLIC_* vars are inlined at build time. After changing them on
# Vercel, Redeploy (a runtime-only env change is not enough).

# --- Required on Vercel Production + Preview ---
# Canonical / Open Graph / Twitter absolute URL base (metadataBase).
NEXT_PUBLIC_SITE_URL=https://www.ankerprotocol.xyz

# --- Optional overrides (leave unset in Production unless you mean to) ---
# Must stay testnet; any other value throws at boot.
# NEXT_PUBLIC_SUI_NETWORK=testnet

# Mysten Predict / Propbook / Sui endpoints (defaults = public testnet).
# NEXT_PUBLIC_PREDICT_SERVER_URL=https://predict-server-beta.testnet.mystenlabs.com
# NEXT_PUBLIC_PROPBOOK_SERVER_URL=https://propbook.api.testnet.mystenlabs.com
# NEXT_PUBLIC_SUI_GRPC_URL=https://fullnode.testnet.sui.io:443
# NEXT_PUBLIC_SUI_GRAPHQL_URL=https://graphql.testnet.sui.io/graphql

# Anker Move package IDs — prefer deployments/testnet.json; do not paste stale README values.
# NEXT_PUBLIC_ANKER_PACKAGE_ID=
# NEXT_PUBLIC_ANKER_ORIGINAL_PACKAGE_ID=
# NEXT_PUBLIC_ANKER_REGISTRY_ID=
# NEXT_PUBLIC_ANKER_ADMIN_CAP_ID=

# --- Enoki zkLogin (Google sign-in; both required to enable) ---
# Public API key from the Enoki Portal (Public type, Testnet, zkLogin enabled).
# Safe to expose client-side; scoped by the portal's Auth Providers config.
# NEXT_PUBLIC_ENOKI_API_KEY=
# Google OAuth Client ID (GCP); must also be registered under Auth Providers
# in the Enoki Portal. Changing it orphans existing zkLogin wallets (see FAQ).
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Enoki gas sponsorship (server-only, never NEXT_PUBLIC_) ---
# Private API key (Private type, Testnet, Sponsored Transactions enabled).
# Unset = sponsorship disabled; zkLogin sessions then need faucet SUI to pay
# their own gas. Extension wallets always self-pay either way.
# ENOKI_PRIVATE_API_KEY=

# --- Feature flags (default off; never enable E2E on Production) ---
# NEXT_PUBLIC_ANKER_DEMO_MODE=false
# ENABLE_EXPERIMENTAL_PRODUCTS=false
# NEXT_PUBLIC_ENABLE_EXPERIMENTAL_PRODUCTS=false
# ANKER_DETERMINISTIC_E2E=false
# NEXT_PUBLIC_ANKER_DETERMINISTIC_E2E=false
# DEMO_ALLOW_UNSIMULATED_TX=false
# NEXT_PUBLIC_DEMO_ALLOW_UNSIMULATED_TX=false

# --- Benchmark Recorder (ADR-0005; server-only, never NEXT_PUBLIC_) ---
# Neon Postgres connection string (Vercel Marketplace / Neon console).
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Vercel Cron Authorization: Bearer <CRON_SECRET> (also required for manual triggers).
# CRON_SECRET=
# GitHub Issues alerts after each Run (#16). Token needs `issues: write` on the repo.
# Leave unset to skip posting (Runs still persist).
# GITHUB_ALERTS_TOKEN=
# GITHUB_ALERTS_REPO=cl-fi/AnkerProtocol
