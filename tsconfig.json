{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "next-env.d.ts",
    "app",
    "src",
    "tests",
    "vitest.config.ts",
    "playwright.config.ts",
    ".next/types/**/*.ts",
    ".next-e2e/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
